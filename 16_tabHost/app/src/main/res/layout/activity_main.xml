<?xml version="1.0" encoding="utf-8"?>
<TabHost xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@android:id/tabhost"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        >
        <FrameLayout
            android:id="@android:id/tabcontent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="1"
            >
            <ImageView
                android:id="@+id/img_cat"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/img_cat"
                />
            <ImageView
                android:id="@+id/img_frog"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/img_frog"
                />
            <ImageView
                android:id="@+id/img_goat"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/img_goat"
                />
            <ImageView
                android:id="@+id/img_donkey"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/img_donkey"
                />
        </FrameLayout>

        <TabWidget
            android:id="@android:id/tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
        </TabWidget>

    </LinearLayout>
</TabHost>